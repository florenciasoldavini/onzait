{
  "expo": {
    "name": "onzait",
    "slug": "onzait",
    "version": "1.0.0",
    "platforms": ["ios", "android", "web"],
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "onzait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.florenciasoldavini.onzait",
      "requireFullScreen": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow onzait to show your current location on the projects map while you are using the app."
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "package": "com.florenciasoldavini.onzait",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "orientation": "any",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "organization": "florencia-soldavini",
          "project": "onzait"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-placeholder.png",
          "imageWidth": 1,
          "resizeMode": "contain",
          "backgroundColor": "#000a33"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow onzait to access your photo library so you can choose profile photos and project cover images."
        }
      ],
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Geist-Black.ttf",
            "./assets/fonts/Geist-Bold.ttf",
            "./assets/fonts/Geist-Medium.ttf",
            "./assets/fonts/Geist-Regular.ttf",
            "./assets/fonts/Geist-SemiBold.ttf",
            "./assets/fonts/JetBrainsMono-Bold.ttf",
            "./assets/fonts/JetBrainsMono-Medium.ttf",
            "./assets/fonts/JetBrainsMono-Regular.ttf",
            "./assets/fonts/JetBrainsMono-SemiBold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cfe1b670-171b-4fb9-808a-78cbbe47ed33"
      }
    },
    "owner": "florenciasoldavini"
  }
}
