# Frontend / Public
EXPO_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_publishable_key"
EXPO_PUBLIC_SENTRY_DSN="https://public-key@o0000000000000000.ingest.us.sentry.io/0000000000000000"
# Public app base URL for auth redirects and hosted web links.
EXPO_PUBLIC_SITE_URL="https://onzait.vercel.app"

# Sentry / Optional Build-Time Source Maps
# Optional build-time Sentry settings for native/web sourcemap uploads.
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"
SENTRY_AUTH_TOKEN="sntrys_your_auth_token"

# Runtime / Optional
# Optional helper to distinguish development/preview/production in runtime telemetry.
EXPO_PUBLIC_APP_ENV="development"

# Supabase Edge Functions / Secrets
# Server-side Google Maps Platform key used only by Places Edge Functions. Set with Supabase secrets, not Expo public env vars.
GOOGLE_MAPS_API_KEY="AIza-your-server-side-google-maps-key"

# Backend / Prisma
DATABASE_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
