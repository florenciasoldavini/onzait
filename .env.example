# Frontend / Public
EXPO_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_publishable_key"
EXPO_PUBLIC_SENTRY_DSN="https://public-key@o0000000000000000.ingest.us.sentry.io/0000000000000000"
# Public app base URL for auth redirects and hosted web links.
EXPO_PUBLIC_SITE_URL="https://onzait.vercel.app"

# Sentry / Optional Build-Time Source Maps
# Optional build-time Sentry settings for native/web sourcemap uploads.
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"
SENTRY_AUTH_TOKEN="sntrys_your_auth_token"

# Runtime / Optional
# Optional helper to distinguish development/preview/production in runtime telemetry.
EXPO_PUBLIC_APP_ENV="development"

# Supabase Edge Functions / Secrets
# Server-side Google Maps Platform key used only by Maps Edge Functions. Set with Supabase secrets, not Expo public env vars.
GOOGLE_MAPS_API_KEY="AIza-your-server-side-google-maps-key"
# Optional hard monthly cap before Places autocomplete calls reach Google. Defaults to 500 when unset. Set with Supabase secrets.
GOOGLE_MAPS_AUTOCOMPLETE_MONTHLY_LIMIT="500"
# Optional hard monthly cap before Place Details calls reach Google. Defaults to 100 when unset. Set with Supabase secrets.
GOOGLE_MAPS_PLACE_DETAILS_MONTHLY_LIMIT="100"
# Optional hard monthly cap before Maps Static preview calls reach Google. Defaults to 100 when unset. Set with Supabase secrets.
GOOGLE_MAPS_STATIC_MONTHLY_LIMIT="100"

# Email / Server
# Server-side Resend API key for transactional emails.
RESEND_API_KEY="re_your_resend_api_key"
# Default sender for server-side product emails.
EMAIL_FROM="Onzait <onboarding@resend.dev>"
# Optional reply-to mailbox for product emails.
EMAIL_REPLY_TO="hello@example.com"
# Canonical app URL used in server-rendered product emails.
SITE_URL="https://onzait.vercel.app"

# Backend / Prisma
DATABASE_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
