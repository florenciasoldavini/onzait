{
  "name": "onzait",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile-first construction project workspace for web, iOS, and Android.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florenciasoldavini/onzait.git"
  },
  "bugs": {
    "url": "https://github.com/florenciasoldavini/onzait/issues"
  },
  "homepage": "https://onzait.vercel.app",
  "author": {
    "name": "Florencia Soldavini",
    "url": "https://github.com/florenciasoldavini"
  },
  "keywords": [
    "construction-management",
    "project-management",
    "job-site",
    "expo",
    "react-native",
    "web",
    "ios",
    "android"
  ],
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "build": "expo export --platform web",
    "env:example": "node ./scripts/generate-env-example.js",
    "env:check": "node ./scripts/generate-env-example.js --check",
    "email:dev": "react-email dev --dir supabase/functions/_shared/email",
    "functions:check": "deno task --config supabase/functions/deno.json check",
    "functions:lint": "deno task --config supabase/functions/deno.json lint",
    "functions:test": "deno task --config supabase/functions/deno.json test",
    "functions:verify": "deno task --config supabase/functions/deno.json verify",
    "sync:env": "node ./scripts/sync-env.js",
    "android": "DARK_MODE=media expo start --android",
    "ios": "DARK_MODE=media expo start --ios",
    "web": "DARK_MODE=media expo start --web",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
