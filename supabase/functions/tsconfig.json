{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["./types/deno"]
  },
  "include": ["**/*.ts", "**/*.tsx", "types/**/*.d.ts"]
}
